# ── AWS Configuration ─────────────────────────────────────────────────────────
# Your AWS region (e.g. us-east-1, ca-central-1)
AWS_REGION=us-east-1

# ARN of your SNS topic for alerts and daily summaries
# Found in AWS Console → SNS → Topics → your topic → ARN
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:your-account-id:your-topic-name

# ── Anomaly Detection Thresholds ──────────────────────────────────────────────
# Daily spend limit in USD before an alert fires
SPEND_THRESHOLD=50

# EC2 CPU utilization percentage before an alert fires
EC2_CPU_THRESHOLD=85

# Number of Lambda errors in 24 hours before an alert fires
LAMBDA_ERROR_THRESHOLD=50

# Multiplier applied to monthly threshold for projected spend alerts
# e.g. 1.5 means alert if projected spend is 1.5x your expected monthly budget
PROJECTED_MULTIPLIER=1.5